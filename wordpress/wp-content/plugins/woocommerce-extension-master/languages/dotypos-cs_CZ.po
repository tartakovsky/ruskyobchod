#. Plugin Name of the plugin
#: dotypos.php:686 build/index.js:1
msgid "Dotypos"
msgstr "Dotykačka"

#. Plugin URI of the plugin
msgid "https://www.dotykacka.cz/woocommerce/"
msgstr "https://www.dotykacka.cz/woocommerce/"

#. Description of the plugin
msgid ""
"The plugin enables connection and synchronization: categories, products and "
"stock status between the e-shop and the Dotypos cash register system."
msgstr ""
"Plugin umožňuje propojení a synchronizaci: kategorií, produktů a stavů "
"skladů mezi e-shopem a pokladním systémem Dotykačka."

#. Author of the plugin
msgid "Jagu s.r.o."
msgstr "Jagu s.r.o."

#. Author URI of the plugin
msgid "https://jagu.cz/"
msgstr "https://jagu.cz/"

