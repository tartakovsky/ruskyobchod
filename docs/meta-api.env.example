# Copy values into your shell session. Do not commit real tokens.

# Graph API version. Leave default unless Meta forces an upgrade.
META_GRAPH_VERSION=v24.0

# Facebook Page ID used by Graph API publishing.
META_PAGE_ID=

# Instagram Business Account ID connected to the Facebook Page.
# Needed only for a future Instagram publish-time job, not for Facebook photo scheduling.
META_IG_USER_ID=

# Long-lived Page access token with pages_manage_posts.
META_PAGE_ACCESS_TOKEN=

# Optional short-lived user token for discovery only.
# Use it to call /me/accounts and find the Page ID/token pair.
META_USER_ACCESS_TOKEN=

